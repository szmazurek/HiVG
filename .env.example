# HiVG path configuration template.
#
# Copy this file to HiVG/.env and fill in the paths for your machine/cluster:
#   cp .env.example .env
#
# .env is sourced (via train_and_eval_script/_load_env.sh) by every script in
# train_and_eval_script/ and by smoke_test_all_training.sh, so none of them
# hardcode a machine-specific data/checkpoint/output path. Anything already
# exported in the calling shell takes precedence over these defaults, so you
# can still override any single value per-invocation, e.g.:
#   OUT_ROOT=/tmp/scratch_run bash train_and_eval_script/train_unc_loopvit.sh

: "${DATA_ROOT:=/path/to/grounding_data}"
: "${SPLIT_ROOT:=/path/to/grounding_data/data}"

# ViT-B/16 backbones distilled by this repo's CLIP-KD training.
: "${STANDARDVIT_CKPT:=/path/to/standardvit_checkpoint.ckpt}"
: "${LOOPVIT_CKPT:=/path/to/loopvit_checkpoint.ckpt}"

# Original OpenAI-CLIP-based checkpoints used by the *_hilora_* / template
# train_and_eval_script/*.sh scripts.
: "${CLIP_CKPT:=/path/to/clip_b_ml_cascade_maskrcnn_model_224.pth}"
: "${CLIP_CKPT_LARGE:=/path/to/clip_l_ml_cascade_maskrcnn_model_224.pth}"

# Where training/eval runs write checkpoints and logs.
: "${OUT_ROOT:=/path/to/HiVG_outputs}"
: "${SMOKE_OUT_ROOT:=/path/to/HiVG_outputs_smoketest}"
